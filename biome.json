{
	"$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
	"assist": {
		"enabled": true,
		"actions": {
			"source": {
				"organizeImports": "on"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"includes": [
			"**/src/**/*",
			"!**/gql/*.ts",
			"!**/dist/**/*",
			"!**/*.generated.ts",
			"!**/*.gen.ts",
			"!./.pnp.cjs"
		]
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"suspicious": {
				"noArrayIndexKey": "info"
			}
		},
		"includes": [
			"**/src/**/*",
			"!**/gql/*.ts",
			"!**/dist/**/*",
			"!**/*.generated.ts",
			"!**/*.gen.ts"
		]
	},
	"overrides": [
		{
			"includes": [
				"./packages/backend/src/**/*",
				"./packages/data/src/**/*",
				"./packages/gameloop/src/**/*"
			],
			"linter": {
				"rules": {
					"correctness": {
						"useImportExtensions": {
							"fix": "safe",
							"level": "error",
							"options": {
								"forceJsExtensions": false,
								"extensionMappings": {
									"ts": "ts"
								}
							}
						}
					}
				}
			}
		}
	]
}
