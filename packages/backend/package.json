{
	"name": "@space/backend",
	"scripts": {
		"dev": "nodemon -q ./src/main.ts",
		"typecheck": "tsc --noEmit"
	},
	"type": "module",
	"devDependencies": {
		"@eddeee888/gcg-typescript-resolver-files": "0.12.1",
		"@graphql-codegen/cli": "5.0.7",
		"@swc/cli": "0.7.8",
		"@swc/core": "1.13.3",
		"@types/bcrypt": "6.0.0",
		"@types/node": "24.3.0",
		"nodemon": "3.1.10",
		"tsx": "4.20.4",
		"typescript": "5.9.2",
		"vitest": "3.2.4"
	},
	"nodemonConfig": {
		"exec": "node --import=tsx --env-file=.env",
		"ignore": [
			"**/*.spec.ts"
		],
		"watch": [
			"src/*.ts",
			"src/schema/**/*.ts",
			"../gameloop/src/**/*.ts"
		],
		"ext": "ts,tsx",
		"signal": "SIGHUP",
		"delay": 500
	},
	"dependencies": {
		"@graphql-yoga/plugin-defer-stream": "3.15.1",
		"@graphql-yoga/plugin-jwt": "3.9.1",
		"@space/data": "workspace:*",
		"@space/gameloop": "workspace:*",
		"@whatwg-node/server-plugin-cookies": "1.0.5",
		"bcrypt": "6.0.0",
		"dayjs": "1.11.13",
		"graphql": "16.11.0",
		"graphql-scalars": "1.24.2",
		"graphql-yoga": "5.15.1",
		"jose": "6.0.12",
		"rxjs": "7.8.2"
	}
}
