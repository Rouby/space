{
	"name": "@space/backend",
	"scripts": {
		"dev": "nodemon -q ./src/main.ts",
		"typecheck": "tsc --noEmit"
	},
	"type": "module",
	"devDependencies": {
		"@eddeee888/gcg-typescript-resolver-files": "0.15.0",
		"@graphql-codegen/cli": "6.2.1",
		"@swc/cli": "0.7.10",
		"@swc/core": "1.15.18",
		"@types/bcrypt": "6.0.0",
		"@types/node": "24.12.0",
		"nodemon": "3.1.14",
		"tsx": "4.21.0",
		"typescript": "5.9.3",
		"vitest": "3.2.4"
	},
	"nodemonConfig": {
		"exec": "node --import=tsx --env-file-if-exists=.env",
		"ignore": [
			"**/*.spec.ts"
		],
		"watch": [
			"src/*.ts",
			"src/schema/**/*.ts",
			"../gameloop/src/**/*.ts"
		],
		"ext": "ts,tsx",
		"signal": "SIGHUP",
		"delay": 500
	},
	"dependencies": {
		"@graphql-yoga/plugin-defer-stream": "3.18.1",
		"@graphql-yoga/plugin-jwt": "3.12.1",
		"@space/data": "workspace:*",
		"@space/gameloop": "workspace:*",
		"@whatwg-node/server-plugin-cookies": "1.0.5",
		"bcrypt": "6.0.0",
		"dayjs": "1.11.20",
		"graphql": "16.13.1",
		"graphql-scalars": "1.25.0",
		"graphql-yoga": "5.18.1",
		"jose": "6.2.1",
		"rxjs": "7.8.2"
	}
}
