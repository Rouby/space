{
	"name": "@space/backend",
	"scripts": {
		"dev": "nodemon -q ./src/main.ts"
	},
	"type": "module",
	"devDependencies": {
		"@eddeee888/gcg-typescript-resolver-files": "0.10.4",
		"@graphql-codegen/cli": "5.0.5",
		"@swc/cli": "0.4.1-nightly.20240914",
		"@swc/core": "1.11.1",
		"@types/bcrypt": "5.0.2",
		"@types/node": "22.13.5",
		"nodemon": "3.1.9",
		"tsx": "4.19.3",
		"typescript": "5.7.3",
		"vitest": "3.0.7"
	},
	"nodemonConfig": {
		"exec": "node --import=tsx --env-file=.env",
		"ignore": [
			"**/*.spec.ts"
		],
		"watch": [
			"src/*.ts",
			"src/schema/**/*.ts",
			"../gameloop/src/**/*.ts"
		],
		"ext": "ts,tsx",
		"signal": "SIGHUP",
		"delay": 500
	},
	"dependencies": {
		"@graphql-yoga/plugin-defer-stream": "3.12.1",
		"@graphql-yoga/plugin-jwt": "3.6.1",
		"@space/data": "workspace:*",
		"@space/gameloop": "workspace:*",
		"@whatwg-node/server-plugin-cookies": "1.0.4",
		"bcrypt": "5.1.1",
		"dayjs": "1.11.13",
		"graphql": "16.10.0",
		"graphql-scalars": "1.24.1",
		"graphql-yoga": "5.12.1",
		"jose": "5.10.0",
		"rxjs": "7.8.2"
	}
}
